        if (paths.jobsPath && fs.existsSync(paths.jobsPath)) {
          const raw = fs.readFileSync(paths.jobsPath, 'utf-8');
          const jobs = JSON.parse(raw || '[]');
          const insert = db.transaction((arr) => {
