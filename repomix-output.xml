function readUsers() {
  try {
    let users = [];
    if (db && db.available) {
      users = db.getAllUsers() || [];
    } else {
      if (!fs.existsSync(dataPath)) return [];
      const raw = fs.readFileSync(dataPath, 'utf-8');
      users = JSON.parse(raw || '[]');
    }
    return users.map(u => decryptUser(u));
  } catch (err) {
    console.error('readUsers error', err);
    return [];
  }
}

function writeUsers(users) {
  const encrypted = users.map(u => encryptUser(u));
  if (db && db.available) {
    try {
      for (const u of encrypted) db.upsertUser(u);
    } catch (e) {
      console.error('db upsert users error', e);
    }
  }
  fs.writeFileSync(dataPath, JSON.stringify(encrypted, null, 2), 'utf-8');
}

