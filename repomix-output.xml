// Setup 2FA — generate TOTP secret + QR code
app.post('/auth/2fa/setup', authenticate, (req, res) => {
  try {
    const users = readUsers();
    const idx = users.findIndex(u => u.id === req.user.id);
    if (idx === -1) return res.status(404).json({ error: 'User not found' });
    if (users[idx].totp_enabled) return res.status(400).json({ error: '2FA is already enabled. Disable it first to reset.' });

    const secret = speakeasy.generateSecret({ name: 'JobBridge:' + users[idx].email });
    // Store temporary secret (not yet activated)
    users[idx].totp_temp_secret = secret.base32;
    writeUsers(users);

    // Generate QR code as data URL
    QRCode.toDataURL(secret.otpauth_url, (err, dataUrl) => {
      if (err) return res.status(500).json({ error: 'Failed to generate QR code' });
      return res.json({ success: true, secret: secret.base32, qrCode: dataUrl });
    });
  } catch (err) {
    console.error('2fa setup error', err);
    return res.status(500).json({ error: 'Internal error' });
  }
});

// Verify 2FA setup — confirm TOTP code to activate
app.post('/auth/2fa/verify', authenticate, (req, res) => {
  try {
    const { token } = req.body;
    if (!token) return res.status(400).json({ error: 'Token required' });

    const users = readUsers();
    const idx = users.findIndex(u => u.id === req.user.id);
    if (idx === -1) return res.status(404).json({ error: 'User not found' });
    if (!users[idx].totp_temp_secret) return res.status(400).json({ error: 'No 2FA setup in progress. Call setup first.' });

    const verified = speakeasy.totp.verify({
      secret: users[idx].totp_temp_secret,
      encoding: 'base32',
      token,
      window: 1,
    });

    if (!verified) return res.status(400).json({ error: 'Invalid code. Try again.' });

    users[idx].totp_enabled = true;
    users[idx].totp_secret = users[idx].totp_temp_secret;
    delete users[idx].totp_temp_secret;
    writeUsers(users);
    auditLog('2FA_ENABLED', { user: req.user.email, ip: req.ip });
    return res.json({ success: true, message: 'Two-factor authentication enabled' });
  } catch (err) {
    console.error('2fa verify error', err);
    return res.status(500).json({ error: 'Internal error' });
  }
});

// Disable 2FA — requires password confirmation
app.post('/auth/2fa/disable', authenticate, (req, res) => {
  try {
    const { password } = req.body;
    if (!password) return res.status(400).json({ error: 'Password required to disable 2FA' });

    const users = readUsers();
    const idx = users.findIndex(u => u.id === req.user.id);
    if (idx === -1) return res.status(404).json({ error: 'User not found' });
    if (!users[idx].totp_enabled) return res.status(400).json({ error: '2FA is not enabled' });

    if (!bcrypt.compareSync(password, users[idx].password_hash)) {
      return res.status(401).json({ error: 'Invalid password' });
    }

    delete users[idx].totp_enabled;
    delete users[idx].totp_secret;
    delete users[idx].totp_temp_secret;
    writeUsers(users);
    auditLog('2FA_DISABLED', { user: req.user.email, ip: req.ip });
    return res.json({ success: true, message: 'Two-factor authentication disabled' });
  } catch (err) {
    console.error('2fa disable error', err);
    return res.status(500).json({ error: 'Internal error' });
  }
});

