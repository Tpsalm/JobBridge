// Login endpoint -> returns basic user info
app.post('/login', authLimiter, async (req, res) => {
  const { email, password, turnstileToken } = req.body;
  if (!email || !password) return res.status(400).json({ error: 'email and password required' });

  // Verify Turnstile if configured
  if (TURNSTILE_SECRET && !(await verifyTurnstile(turnstileToken))) {
    return res.status(400).json({ error: 'CAPTCHA verification failed. Please try again.' });
  }

  try {
    const ip = req.headers['x-forwarded-for'] || req.socket.remoteAddress || 'unknown';
    const lockoutKey = `login:${email}:${ip}`;

    if (checkLockout(lockoutKey)) {
      auditLog('LOGIN_BLOCKED_LOCKOUT', { email, ip });
      return res.status(429).json({ error: 'Account temporarily locked due to too many failed attempts. Try again in 30 minutes.' });
    }

    const users = readUsers();
    const user = users.find(u => u.email === email);
    if (!user || !bcrypt.compareSync(password, user.password_hash)) {
      recordFailedAttempt(lockoutKey);
      auditLog('LOGIN_FAILED', { email, ip });
      return res.status(401).json({ error: 'Invalid email or password' });
    }

    // Clear password lockout
    loginAttempts.delete(lockoutKey);

    // If 2FA is enabled, issue a temporary token and require TOTP
    if (user.totp_enabled) {
      const tempToken = jwt.sign(
        { id: user.id, email: user.email, role: user.role, totp_required: true },
        JWT_SECRET,
        { expiresIn: '5m' }
      );
      auditLog('LOGIN_2FA_REQUIRED', { email: user.email, ip });
      return res.json({ success: true, requires_2fa: true, temp_token: tempToken, email: user.email });
    }

    const { password_hash, ...safe } = user;
    const token = issueToken(user, res);
    auditLog('LOGIN_SUCCESS', { email: safe.email, role: safe.role, ip });
    return res.json({ success: true, user: safe, token });
  } catch (err) {
    console.error('login error', err);
    return res.status(500).json({ error: 'Internal error' });
  }
});

// 2FA login step — verify TOTP code with temp token
app.post('/auth/2fa/login', authLimiter, (req, res) => {
  const { temp_token, totp_code } = req.body;
  if (!temp_token || !totp_code) return res.status(400).json({ error: 'Temp token and TOTP code required' });

  try {
    const payload = jwt.verify(temp_token, JWT_SECRET);
    if (!payload.totp_required) return res.status(400).json({ error: 'Invalid temp token' });

    const users = readUsers();
    const user = users.find(u => u.id === payload.id);
    if (!user || !user.totp_enabled || !user.totp_secret) {
      return res.status(400).json({ error: '2FA is not enabled for this account' });
    }

    const verified = speakeasy.totp.verify({
      secret: user.totp_secret,
      encoding: 'base32',
      token: totp_code,
      window: 1,
    });

    if (!verified) {
      auditLog('LOGIN_2FA_FAILED', { email: user.email, ip: req.ip });
      return res.status(401).json({ error: 'Invalid TOTP code' });
    }

    const { password_hash, ...safe } = user;
    const token = issueToken(user, res);
    auditLog('LOGIN_2FA_SUCCESS', { email: safe.email, ip: req.ip });
    return res.json({ success: true, user: safe, token });
  } catch (err) {
    if (err.name === 'TokenExpiredError') return res.status(401).json({ error: 'Temp token expired. Please login again.' });
    console.error('2fa login error', err);
    return res.status(500).json({ error: 'Internal error' });
  }
});

