              });
            }
          });
          insert(jobs);
        }
      } catch (e) {
        console.error('DB migration error', e);
      }
    }
  };
} catch (err) {
  console.warn('better-sqlite3 not available, falling back to JSON storage');
  module.exports = { available: false };
}
